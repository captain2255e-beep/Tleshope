// ลบหมวดหมู่ออกจาก Google Sheets
async function deleteCategory(cat){
  const inUse = products.some(p => p.category === cat);
  if(inUse){
    showToast('ไม่สามารถลบได้ เนื่องจากมีสินค้าที่ใช้หมวดหมู่นี้อยู่', 'error');
    return;
  }
  
  let res = await deleteFromSheet('categories', 'name', cat);
  if(res && res.status === 'success') {
    categories = categories.filter(c => c !== cat);
    renderAdminCategoryList();
    populateCategoryDropdown();
    renderCategoryChips();
    if(currentCategoryFilter === cat){ currentCategoryFilter = 'all'; renderProductGrid(); }
    showToast('ลบหมวดหมู่แล้ว', 'info');
  }
}

function populateCategoryDropdown(){
  const select = document.getElementById('pCategory');
  if(!select) return;
  select.innerHTML = categories.map(c => `<option value="${escapeHtml(c)}">${escapeHtml(c)}</option>`).join('');
}

// เพิ่มสินค้าลง Google Sheets
document.getElementById('productForm').addEventListener('submit', async function(e){
  e.preventDefault();
  const name = document.getElementById('pName').value.trim();
  const price = parseFloat(document.getElementById('pPrice').value);
  const cost = parseFloat(document.getElementById('pCost').value);
  const category = document.getElementById('pCategory').value;
  const barcode = document.getElementById('pBarcode').value.trim();

  if(!name || isNaN(price) || isNaN(cost) || !category || !barcode) return;

  if(products.some(p => String(p.barcode) === barcode)){
    showToast('มีรหัสบาร์โค้ดนี้อยู่แล้วในระบบ', 'error');
    return;
  }

  const newProduct = { id: genId(), name, price, cost, category, barcode };
  
  let res = await insertToSheet('products', newProduct);
  if(res && res.status === 'success') {
    products.push(newProduct);
    this.reset();
    renderAdminProductTable();
    renderProductGrid(); 
    showToast('เพิ่มสินค้าลงคลังสำเร็จ', 'success');
