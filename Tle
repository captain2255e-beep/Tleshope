function switchAdminTab(tab){
  document.querySelectorAll('.admin-tab-content').forEach(el => el.classList.add('d-none'));
  document.getElementById('tab-' + tab).classList.remove('d-none');
  document.querySelectorAll('.admin-sidebar .list-group-item').forEach(btn => btn.classList.remove('active'));
  document.querySelector(`.admin-sidebar [data-tab="${tab}"]`).classList.add('active');

  if(tab === 'report') renderReport();
  if(tab === 'products') renderAdminProductTable();
  if(tab === 'categories') renderAdminCategoryList();
