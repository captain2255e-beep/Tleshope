<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1">
<title>TleShope | ระบบร้านค้าอัจฉริยะ</title>

<!-- ========================= EXTERNAL LIBRARIES ========================= -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
:root{
  --purple-900:#4C1D95;
  --purple-700:#6D28D9;
  --purple-600:#7C3AED;
  --purple-500:#8B5CF6;
  --purple-100:#EDE9FE;
  --purple-50:#F5F3FF;
  --white:#FFFFFF;
  --gray-50:#F8F7FC;
  --gray-100:#F1EFFB;
  --gray-600:#6B7280;
  --gray-800:#1F2937;
  --danger:#DC2626;
  --success:#16A34A;
  --radius-lg:18px;
  --radius-md:12px;
  --shadow-soft:0 6px 24px rgba(124,58,237,0.10);
  --shadow-strong:0 10px 40px rgba(76,29,149,0.18);
}

*{ font-family:'Kanit', sans-serif; }

body{
  background:var(--gray-50);
  color:var(--gray-800);
  padding-bottom:40px;
}

.navbar-tleshope{
  background:linear-gradient(90deg,var(--purple-700) 0%,var(--purple-500) 100%);
  box-shadow:var(--shadow-soft);
}
.navbar-tleshope .navbar-brand{
  font-weight:700;
  font-size:1.5rem;
  color:#fff !important;
  letter-spacing:.5px;
}
.navbar-tleshope .navbar-brand i{ color:#FDE68A; }
.nav-pill-btn{
  border-radius:999px !important;
  padding:.45rem 1.1rem !important;
  font-weight:500;
  color:#fff !important;
  opacity:.85;
  transition:.2s;
}
.nav-pill-btn.active, .nav-pill-btn:hover{
  background:rgba(255,255,255,.18);
  opacity:1;
}

.card-surface{
  background:var(--white);
  border:1px solid var(--purple-100);
  border-radius:var(--radius-lg);
  box-shadow:var(--shadow-soft);
}
.section-title{
  font-weight:600;
  color:var(--purple-900);
}

.btn-purple{
  background:var(--purple-600);
  border-color:var(--purple-600);
  color:#fff;
  font-weight:500;
}
.btn-purple:hover{ background:var(--purple-700); border-color:var(--purple-700); color:#fff; }
.btn-outline-purple{
  border:1.5px solid var(--purple-500);
  color:var(--purple-700);
  font-weight:500;
  background:#fff;
}
.btn-outline-purple:hover{ background:var(--purple-500); color:#fff; }
.btn-soft-purple{
  background:var(--purple-50);
  color:var(--purple-700);
  border:1px solid var(--purple-100);
  font-weight:500;
}
.btn-soft-purple:hover{ background:var(--purple-100); }

.category-chip{
  border-radius:999px;
  padding:.5rem 1.15rem;
  border:1.5px solid var(--purple-100);
  background:#fff;
  color:var(--purple-700);
  font-weight:500;
  white-space:nowrap;
  transition:.15s;
  cursor:pointer;
}
.category-chip:hover{ border-color:var(--purple-500); }
.category-chip.active{
  background:var(--purple-600);
  border-color:var(--purple-600);
  color:#fff;
  box-shadow:var(--shadow-soft);
}

.product-card{
  border-radius:var(--radius-lg);
  border:1px solid var(--purple-100);
  background:#fff;
  overflow:hidden;
  transition:.2s;
  height:100%;
}
.product-card:hover{
  transform:translateY(-4px);
  box-shadow:var(--shadow-strong);
  border-color:var(--purple-50);
}
.product-img-placeholder{
  height:130px;
  background:linear-gradient(135deg,var(--purple-50),var(--purple-100));
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:2.4rem;
  color:var(--purple-500);
}
.product-barcode-text{
  font-size:.72rem;
  color:var(--gray-600);
  letter-spacing:.5px;
}
.product-price{
  font-weight:700;
  color:var(--purple-700);
  font-size:1.15rem;
}

.scan-bar{
  background:linear-gradient(135deg,var(--purple-900),var(--purple-600));
  border-radius:var(--radius-lg);
  padding:1.1rem 1.3rem;
  box-shadow:var(--shadow-strong);
}
.scan-bar input::placeholder{ color:#DDD6FE; }
.scan-bar input{
  background:rgba(255,255,255,.12);
  border:1.5px solid rgba(255,255,255,.35);
  color:#fff;
}
.scan-bar input:focus{
  background:rgba(255,255,255,.18);
  border-color:#fff;
  color:#fff;
  box-shadow:none;
}

.offcanvas-purple .offcanvas-header{
  background:var(--purple-600);
  color:#fff;
}
.cart-item-row{
  border-bottom:1px dashed var(--purple-100);
  padding:.7rem 0;
}
.qty-btn{
  width:28px; height:28px;
  border-radius:8px;
  border:1px solid var(--purple-200,#DDD6FE);
  background:var(--purple-50);
  color:var(--purple-700);
  display:inline-flex;align-items:center;justify-content:center;
  font-weight:600;
  line-height:1;
}
.floating-cart-btn{
  position:fixed;
  bottom:24px;
  right:24px;
  z-index:1030;
  border-radius:999px;
  padding:.9rem 1.4rem;
  box-shadow:var(--shadow-strong);
}

.receipt-slip{
  font-family:'Kanit', monospace;
  background:#fff;
  border:1.5px dashed var(--purple-300,#C4B5FD);
  border-radius:10px;
  padding:1.4rem;
  max-width:380px;
  margin:0 auto;
}
.receipt-slip hr{ border-top:1.5px dashed var(--purple-100); }
.receipt-slip .r-title{ font-weight:700; color:var(--purple-700); font-size:1.2rem; }
.receipt-row{ display:flex; justify-content:space-between; font-size:.88rem; margin-bottom:2px;}

.admin-sidebar .list-group-item{
  border:none;
  border-radius:var(--radius-md) !important;
  margin-bottom:6px;
  font-weight:500;
  color:var(--gray-800);
}
.admin-sidebar .list-group-item.active{
  background:var(--purple-600);
  color:#fff;
}
.admin-sidebar .list-group-item:hover:not(.active){ background:var(--purple-50); }

.stat-card{
  border-radius:var(--radius-lg);
  padding:1.3rem;
  color:#fff;
  box-shadow:var(--shadow-soft);
}
.stat-card.revenue{ background:linear-gradient(135deg,#7C3AED,#A78BFA); }
.stat-card.cost{ background:linear-gradient(135deg,#F59E0B,#FBBF24); }
.stat-card.profit{ background:linear-gradient(135deg,#16A34A,#4ADE80); }
.stat-card .label{ font-size:.85rem; opacity:.9; }
.stat-card .value{ font-size:1.6rem; font-weight:700; }

#cameraReaderCustomer, #cameraReaderAdmin{
  width:100%;
  border-radius:var(--radius-md);
  overflow:hidden;
  border:2px solid var(--purple-200,#DDD6FE);
}

.login-wrapper{
  min-height:70vh;
  display:flex;
  align-items:center;
  justify-content:center;
}
.login-card{
  width:100%;
  max-width:400px;
  padding:2.2rem;
  border-radius:var(--radius-lg);
  background:#fff;
  box-shadow:var(--shadow-strong);
}

.toast-purple{
  border:none;
  border-radius:var(--radius-md);
  box-shadow:var(--shadow-strong);
}

/* Loading Overlay Screen */
#loadingOverlay {
  position: fixed;
  top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(255,255,255,0.8);
  z-index: 9999;
  display: flex; flex-direction: column;
  justify-content: center; align-items: center;
}

::-webkit-scrollbar{ width:8px; height:8px; }
::-webkit-scrollbar-thumb{ background:var(--purple-200,#DDD6FE); border-radius:8px; }

@media (max-width:576px){
  .floating-cart-btn{ right:16px; bottom:16px; padding:.75rem 1.1rem; }
}
</style>
</head>
<body>

<!-- Loading Screen -->
<div id="loadingOverlay">
  <div class="spinner-border text-primary" role="status" style="color: var(--purple-600) !important;"></div>
  <div class="mt-2 fw-bold" style="color: var(--purple-900);">กำลังเชื่อมต่อ Google Sheets...</div>
</div>

<nav class="navbar navbar-tleshope navbar-expand-lg sticky-top py-2">
  <div class="container">
    <a class="navbar-brand d-flex align-items-center gap-2" href="#">
      <i class="bi bi-shop"></i> TleShope
    </a>
    <div class="d-flex gap-2">
      <button class="btn nav-pill-btn active" id="navCustomerBtn" onclick="switchPage('customer')">
        <i class="bi bi-bag-heart"></i> หน้าร้านค้า
      </button>
      <button class="btn nav-pill-btn" id="navAdminBtn" onclick="switchPage('admin')">
        <i class="bi bi-speedometer2"></i> แอดมิน
      </button>
    </div>
  </div>
</nav>

<div class="container mt-4">

  <!-- PAGE 1: CUSTOMER UI -->
  <div id="customerPage">
    <div class="scan-bar mb-4">
      <div class="row g-2 align-items-center">
        <div class="col-12 col-md-7">
          <label class="text-white small mb-1"><i class="bi bi-upc-scan"></i> ยิง/พิมพ์รหัสบาร์โค้ดแล้วกด Enter</label>
          <input type="text" id="barcodeInput" class="form-control form-control-lg" placeholder="เช่น 8850123456789">
        </div>
        <div class="col-12 col-md-5 d-flex align-items-end gap-2">
          <button class="btn btn-light w-100" onclick="openCameraScanner('customer')">
            <i class="bi bi-camera-fill text-purple"></i> เปิดกล้องแสกนบาร์โค้ด
          </button>
        </div>
      </div>
    </div>

    <div class="d-flex gap-2 overflow-auto pb-2 mb-3" id="categoryChipRow"></div>
    <div class="row g-3" id="productGrid"></div>
  </div>

  <!-- PAGE 2a: ADMIN LOGIN -->
  <div id="adminLoginPage" class="d-none">
    <div class="login-wrapper">
      <div class="login-card">
        <div class="text-center mb-4">
          <i class="bi bi-shield-lock" style="font-size:2.6rem;color:var(--purple-600);"></i>
          <h4 class="mt-2 section-title">เข้าสู่ระบบแอดมิน</h4>
          <div class="text-muted small">TleShope Admin Dashboard</div>
        </div>
        <form id="adminLoginForm">
          <div class="mb-3">
            <label class="form-label">ชื่อผู้ใช้ (Username)</label>
            <input type="text" class="form-control" id="adminUsername" placeholder="1234@admin.ac.th" required>
          </div>
          <div class="mb-3">
            <label class="form-label">รหัสผ่าน (Password)</label>
            <input type="password" class="form-control" id="adminPassword" placeholder="••••••••" required>
          </div>
          <div id="loginError" class="text-danger small mb-2 d-none"><i class="bi bi-exclamation-circle"></i> ชื่อผู้ใช้หรือรหัสผ่านไม่ถูกต้อง</div>
          <button type="submit" class="btn btn-purple w-100 py-2">
            <i class="bi bi-box-arrow-in-right"></i> เข้าสู่ระบบ
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- PAGE 2b: ADMIN DASHBOARD -->
  <div id="adminDashboardPage" class="d-none">
    <div class="row g-3">
      <div class="col-12 col-lg-3">
        <div class="card-surface p-3 admin-sidebar">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <strong class="section-title"><i class="bi bi-grid-1x2"></i> เมนูจัดการ</strong>
          </div>
          <div class="list-group">
            <button class="list-group-item list-group-item-action active" onclick="switchAdminTab('report')" data-tab="report">
              <i class="bi bi-graph-up-arrow"></i> สรุปรายรับ-รายจ่าย
            </button>
            <button class="list-group-item list-group-item-action" onclick="switchAdminTab('products')" data-tab="products">
              <i class="bi bi-box-seam"></i> จัดการสินค้า
            </button>
            <button class="list-group-item list-group-item-action" onclick="switchAdminTab('categories')" data-tab="categories">
              <i class="bi bi-tags"></i> จัดการหมวดหมู่
            </button>
            <button class="list-group-item list-group-item-action" onclick="switchAdminTab('coupons')" data-tab="coupons">
              <i class="bi bi-ticket-perforated"></i> จัดการคูปอง
            </button>
            <button class="list-group-item list-group-item-action" onclick="switchAdminTab('settings')" data-tab="settings">
              <i class="bi bi-qr-code"></i> ตั้งค่าช่องทางรับเงิน
            </button>
          </div>
          <hr>
          <button class="btn btn-outline-danger w-100" onclick="adminLogout()">
            <i class="bi bi-box-arrow-right"></i> ออกจากระบบ
          </button>
        </div>
      </div>

      <div class="col-12 col-lg-9">
        <!-- ===== TAB: รายงานการเงิน ===== -->
        <div id="tab-report" class="admin-tab-content">
          <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
            <h5 class="section-title mb-0"><i class="bi bi-graph-up-arrow"></i> สรุปรายรับ-รายจ่าย</h5>
            <select class="form-select w-auto" id="reportFilter" onchange="renderReport()">
              <option value="today">วันนี้</option>
              <option value="month">เดือนนี้</option>
              <option value="year">ปีนี้</option>
              <option value="all" selected>ทั้งหมด</option>
            </select>
          </div>
          <div class="row g-3 mb-4">
            <div class="col-12 col-md-4">
              <div class="stat-card revenue">
                <div class="label"><i class="bi bi-cash-stack"></i> รายรับรวม</div>
                <div class="value" id="statRevenue">฿0</div>
              </div>
            </div>
            <div class="col-12 col-md-4">
              <div class="stat-card cost">
                <div class="label"><i class="bi bi-box-arrow-down"></i> ต้นทุนรวม</div>
                <div class="value" id="statCost">฿0</div>
              </div>
            </div>
            <div class="col-12 col-md-4">
              <div class="stat-card profit">
                <div class="label"><i class="bi bi-piggy-bank"></i> กำไรสุทธิ</div>
                <div class="value" id="statProfit">฿0</div>
              </div>
            </div>
          </div>
          <div class="card-surface p-3">
            <h6 class="section-title mb-3"><i class="bi bi-receipt"></i> ประวัติธุรกรรม</h6>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr class="text-muted small">
                    <th>วันเวลา</th><th>เลขบิล</th><th>วิธีชำระ</th><th>รายรับ</th><th>ต้นทุน</th>
                  </tr>
                </thead>
                <tbody id="transactionTableBody"></tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- ===== TAB: จัดการสินค้า ===== -->
        <div id="tab-products" class="admin-tab-content d-none">
          <h5 class="section-title mb-3"><i class="bi bi-box-seam"></i> จัดการสินค้า</h5>
          <div class="card-surface p-3 mb-3">
            <form id="productForm" class="row g-2">
              <div class="col-12 col-md-4">
                <label class="form-label small">ชื่อสินค้า</label>
                <input type="text" class="form-control" id="pName" required>
              </div>
              <div class="col-6 col-md-2">
                <label class="form-label small">ราคาขาย (บาท)</label>
                <input type="number" step="0.01" min="0" class="form-control" id="pPrice" required>
              </div>
              <div class="col-6 col-md-2">
                <label class="form-label small">ราคาทุน (บาท)</label>
                <input type="number" step="0.01" min="0" class="form-control" id="pCost" required>
              </div>
              <div class="col-6 col-md-2">
                <label class="form-label small">หมวดหมู่</label>
                <select class="form-select" id="pCategory" required></select>
              </div>
              <div class="col-6 col-md-2">
                <label class="form-label small">รหัสบาร์โค้ด</label>
                <input type="text" class="form-control" id="pBarcode" required>
              </div>
              <div class="col-12 d-flex gap-2 mt-2">
                <button type="button" class="btn btn-soft-purple" onclick="openCameraScanner('admin')">
                  <i class="bi bi-camera"></i> แสกนกล้องเพื่อกรอกบาร์โค้ด
                </button>
                <button type="submit" class="btn btn-purple ms-auto">
                  <i class="bi bi-plus-circle"></i> เพิ่มสินค้า
                </button>
              </div>
            </form>
          </div>
          <div class="card-surface p-3">
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr class="text-muted small">
                    <th>สินค้า</th><th>หมวดหมู่</th><th>บาร์โค้ด</th><th>ราคาขาย</th><th>ราคาทุน</th><th></th>
                  </tr>
                </thead>
                <tbody id="productTableBody"></tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- ===== TAB: จัดการหมวดหมู่ ===== -->
        <div id="tab-categories" class="admin-tab-content d-none">
          <h5 class="section-title mb-3"><i class="bi bi-tags"></i> จัดการหมวดหมู่สินค้า</h5>
          <div class="card-surface p-3 mb-3">
            <form id="categoryForm" class="d-flex gap-2">
              <input type="text" class="form-control" id="newCategoryInput" placeholder="ชื่อหมวดหมู่ใหม่ เช่น เครื่องเขียน" required>
              <button type="submit" class="btn btn-purple text-nowrap"><i class="bi bi-plus-circle"></i> เพิ่ม</button>
            </form>
          </div>
          <div class="card-surface p-3">
            <div class="d-flex flex-wrap gap-2" id="categoryManageList"></div>
          </div>
        </div>

        <!-- ===== TAB: จัดการคูปอง ===== -->
        <div id="tab-coupons" class="admin-tab-content d-none">
          <h5 class="section-title mb-3"><i class="bi bi-ticket-perforated"></i> จัดการคูปองส่วนลด</h5>
          <div class="card-surface p-3 mb-3">
            <form id="couponForm" class="row g-2">
              <div class="col-12 col-md-5">
                <label class="form-label small">โค้ดส่วนลด</label>
                <input type="text" class="form-control text-uppercase" id="couponCode" placeholder="เช่น SAVE50" required>
              </div>
              <div class="col-12 col-md-5">
                <label class="form-label small">ส่วนลด (บาท)</label>
                <input type="number" min="1" step="1" class="form-control" id="couponAmount" required>
              </div>
              <div class="col-12 col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-purple w-100"><i class="bi bi-plus-circle"></i> สร้าง</button>
              </div>
            </form>
          </div>
          <div class="card-surface p-3">
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead><tr class="text-muted small"><th>โค้ด</th><th>ส่วนลด</th><th></th></tr></thead>
                <tbody id="couponTableBody"></tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- ===== TAB: ตั้งค่า QR รับเงิน ===== -->
        <div id="tab-settings" class="admin-tab-content d-none">
          <h5 class="section-title mb-3"><i class="bi bi-qr-code"></i> ตั้งค่าช่องทางรับเงิน (QR Code)</h5>
          <div class="card-surface p-3">
            <p class="text-muted small">อัปโหลดรูป QR Code พร้อมเพย์ / บัญชีธนาคาร เพื่อแสดงในหน้าชำระเงินของลูกค้า</p>
            <input type="file" id="qrUploadInput" accept="image/*" class="form-control mb-3">
            <div id="qrPreviewWrap" class="text-center"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- FLOATING CART BUTTON -->
<button class="btn btn-purple floating-cart-btn" id="floatingCartBtn" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas">
  <i class="bi bi-cart3"></i> ตะกร้า <span class="badge bg-light text-purple ms-1" id="cartCountBadge">0</span>
</button>

<!-- CART OFFCANVAS -->
<div class="offcanvas offcanvas-end offcanvas-purple" tabindex="-1" id="cartOffcanvas" style="width:420px;max-width:95vw;">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title"><i class="bi bi-cart3"></i> ตะกร้าสินค้าของคุณ</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
  </div>
  <div class="offcanvas-body d-flex flex-column">
    <div id="cartItemsWrap" class="flex-grow-1 overflow-auto"></div>
    <div class="mt-3">
      <label class="form-label small text-muted">โค้ดส่วนลด (ถ้ามี)</label>
      <div class="input-group">
        <input type="text" class="form-control text-uppercase" id="couponInput" placeholder="กรอกโค้ดส่วนลด">
        <button class="btn btn-outline-purple" onclick="applyCoupon()">ใช้โค้ด</button>
      </div>
      <div id="couponMsg" class="small mt-1"></div>
