function filterTransactionsByPeriod(period){
  const now = new Date();
  return transactions.filter(tx => {
    const d = new Date(tx.datetime);
    if(period === 'today'){
      return d.toDateString() === now.toDateString();
    }
    if(period === 'month'){
      return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
    }
    if(period === 'year'){
      return d.getFullYear() === now.getFullYear();
    }
    return true; 
  });
}

function renderReport(){
  const period = document.getElementById('reportFilter').value;
  const filtered = filterTransactionsByPeriod(period).sort((a,b) => new Date(b.datetime) - new Date(a.datetime));

  const totalRevenue = filtered.reduce((s,tx) => s + parseFloat(tx.total), 0);
  const totalCost = filtered.reduce((s,tx) => s + parseFloat(tx.cost), 0);
  const totalProfit = totalRevenue - totalCost;

  document.getElementById('statRevenue').textContent = formatBaht(totalRevenue);
  document.getElementById('statCost').textContent = formatBaht(totalCost);
  document.getElementById('statProfit').textContent = formatBaht(totalProfit);

  const tbody = document.getElementById('transactionTableBody');
  if(filtered.length === 0){
    tbody.innerHTML = `<tr><td colspan="5" class="text-center text-muted py-4">ไม่มีข้อมูลธุรกรรมในช่วงเวลานี้</td></tr>`;
    return;
  }
  tbody.innerHTML = filtered.map(tx => {
    const d = new Date(tx.datetime);
    const dateTimeStr = d.toLocaleString('th-TH', { dateStyle:'short', timeStyle:'short' });
    return `
      <tr>
        <td class="small">${dateTimeStr}</td>
        <td class="small">${tx.id}</td>
        <td><span class="badge" style="background:var(--purple-50);color:var(--purple-700);">${tx.paymentMethod}</span></td>
        <td class="text-success">${formatBaht(tx.total)}</td>
        <td class="text-warning">${formatBaht(tx.cost)}</td>
      </tr>
    `;
  }).join('');
}

