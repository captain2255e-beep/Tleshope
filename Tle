// เพิ่มหมวดหมู่ลง Google Sheets
document.getElementById('categoryForm').addEventListener('submit', async function(e){
  e.preventDefault();
  const input = document.getElementById('newCategoryInput');
  const name = input.value.trim();
  if(!name) return;
  if(categories.includes(name)){
    showToast('มีหมวดหมู่นี้อยู่แล้ว', 'warning');
    return;
  }
  
  let res = await insertToSheet('categories', { name: name });
  if(res && res.status === 'success') {
    categories.push(name);
    input.value = '';
    renderAdminCategoryList();
    populateCategoryDropdown();
    renderCategoryChips(); 
    showToast('เพิ่มหมวดหมู่สำเร็จ', 'success');
  }
});

function renderAdminCategoryList(){
  const wrap = document.getElementById('categoryManageList');
  if(categories.length === 0){
    wrap.innerHTML = `<div class="text-muted small">ยังไม่มีหมวดหมู่</div>`;
    return;
  }
  wrap.innerHTML = categories.map(cat => `
    <span class="badge rounded-pill d-flex align-items-center gap-2 py-2 px-3" style="background:var(--purple-50);color:var(--purple-700);border:1px solid var(--purple-100);">
      ${escapeHtml(cat)}
