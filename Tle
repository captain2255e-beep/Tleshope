<script>
/* ============================================================================
   CONFIG: นำ URL ของ Apps Script Web App ที่ Deploy แล้วมาวางที่นี่
   ============================================================================ */
var SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbz-ZHV9uPVLVs0TJPrcLZLBSElkdCTjorrAXibmyfEOTt8WM2jCHPNrn8i3JAegYYMlnA/exec';

const STORAGE_KEYS = {
  qr: 'tleshope_qr_image',
  adminSession: 'tleshope_admin_session'
};

/* state variables (โหลดมาจาก Google Sheets) */
let categories = [];
let products = [];
let coupons = [];
let transactions = [];
let qrImageBase64 = localStorage.getItem(STORAGE_KEYS.qr) || '';

let cart = [];               
let currentCategoryFilter = 'all';
let appliedCoupon = null;    
let html5QrCode = null;      
let cameraScanTarget = 'customer'; 
let pendingPaymentMethod = null;

function showLoading(status) {
  document.getElementById('loadingOverlay').classList.toggle('d-none', !status);
}

// ฟังก์ชันโหลดข้อมูลทั้งหมดมาจาก Google Sheets
async function loadAllDataFromSheets() {
  showLoading(true);
  try {
    let response = await fetch(`${SCRIPT_URL}?action=loadAll`);
    let resData = await response.json();
    products = resData.products;
    categories = resData.categories;
    coupons = resData.coupons;
    transactions = resData.transactions;
    
    initAppUi();
  } catch(e) {
    showToast('ดาวน์โหลดข้อมูลล้มเหลว กรุณาตรวจสอบ URL Apps Script', 'error');
    console.error(e);
  } finally {
    showLoading(false);
  }
}

// ฟังก์ชันบันทึกข้อมูลแบบเพิ่มแถวใหม่ (Insert) ลง Google Sheets
async function insertToSheet(sheetName, dataObj) {
  showLoading(true);
  try {
    let response = await fetch(SCRIPT_URL, {
      method: "POST",
      body: JSON.stringify({ action: "insert", sheet: sheetName, data: dataObj })
    });
    return await response.json();
  } catch(e) {
    showToast('บันทึกข้อมูลลง Sheet ล้มเหลว', 'error');
  } finally {
    showLoading(false);
  }
}

// ฟังก์ชันลบข้อมูลออกจาก Google Sheets
async function deleteFromSheet(sheetName, keyName, keyValue) {
  showLoading(true);
  try {
    let response = await fetch(SCRIPT_URL, {
      method: "POST",
      body: JSON.stringify({ action: "delete", sheet: sheetName, key: keyName, value: keyValue })
    });
    return await response.json();
  } catch(e) {
    showToast('ลบข้อมูลใน Sheet ล้มเหลว', 'error');
  } finally {
    showLoading(false);
  }
}

function genId(){
  return 'id_' + Math.random().toString(36).slice(2, 10) + Date.now().toString(36);
}
function genBillNo(){
  const d = new Date();
  const stamp = d.getFullYear().toString().slice(2) + String(d.getMonth()+1).padStart(2,'0') + String(d.getDate()).padStart(2,'0');
  const rand = Math.floor(1000 + Math.random()*9000);
  return `TS-${stamp}-${rand}`;
}
function formatBaht(num){
  return '฿' + Number(num).toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function showToast(message, type = 'success'){
  const toastEl = document.getElementById('mainToast');
  const body = document.getElementById('toastBody');
  const icons = {
    success: 'bi-check-circle-fill text-success',
    error: 'bi-x-circle-fill text-danger',
    info: 'bi-info-circle-fill text-purple',
    warning: 'bi-exclamation-triangle-fill text-warning'
  };
  toastEl.style.background = '#fff';
  body.innerHTML = `<i class="bi ${icons[type] || icons.info} fs-5"></i><span>${message}</span>`;
  const toast = bootstrap.Toast.getOrCreateInstance(toastEl, { delay: 2600 });
  toast.show();
}

function switchPage(page){
  const customerPage = document.getElementById('customerPage');
  const loginPage = document.getElementById('adminLoginPage');
  const dashboardPage = document.getElementById('adminDashboardPage');
  const floatingCart = document.getElementById('floatingCartBtn');
  const navCustomer = document.getElementById('navCustomerBtn');
  const navAdmin = document.getElementById('navAdminBtn');

  if(page === 'customer'){
    customerPage.classList.remove('d-none');
    loginPage.classList.add('d-none');
    dashboardPage.classList.add('d-none');
    floatingCart.classList.remove('d-none');
    navCustomer.classList.add('active');
    navAdmin.classList.remove('active');
  } else {
    customerPage.classList.add('d-none');
    floatingCart.classList.add('d-none');
    navAdmin.classList.add('active');
    navCustomer.classList.remove('active');
    const isLoggedIn = sessionStorage.getItem(STORAGE_KEYS.adminSession) === 'true';
    if(isLoggedIn){
      loginPage.classList.add('d-none');
      dashboardPage.classList.remove('d-none');
      renderAdminAll();
    } else {
      loginPage.classList.remove('d-none');
      dashboardPage.classList.add('d-none');
    }
  }
}

function renderCategoryChips(){
  const wrap = document.getElementById('categoryChipRow');
  let html = `<button class="category-chip ${currentCategoryFilter==='all'?'active':''}" onclick="filterByCategory('all')">
                <i class="bi bi-grid-3x3-gap"></i> ทั้งหมด
              </button>`;
  categories.forEach(cat => {
    html += `<button class="category-chip ${currentCategoryFilter===cat?'active':''}" onclick="filterByCategory('${escapeHtml(cat)}')">${escapeHtml(cat)}</button>`;
  });
  wrap.innerHTML = html;
}

function filterByCategory(cat){
  currentCategoryFilter = cat;
  renderCategoryChips();
  renderProductGrid();
}

function renderProductGrid(){
  const grid = document.getElementById('productGrid');
  const filtered = currentCategoryFilter === 'all'
    ? products
    : products.filter(p => p.category === currentCategoryFilter);

  if(filtered.length === 0){
    grid.innerHTML = `<div class="col-12 text-center text-muted py-5">
        <i class="bi bi-inbox fs-1"></i><div class="mt-2">ยังไม่มีสินค้าในหมวดหมู่นี้</div>
      </div>`;
    return;
  }

  grid.innerHTML = filtered.map(p => `
    <div class="col-6 col-md-4 col-lg-3">
      <div class="product-card">
        <div class="product-img-placeholder">
          <i class="bi bi-box-seam-fill"></i>
        </div>
        <div class="p-2">
          <div class="fw-500 text-truncate" title="${escapeHtml(p.name)}">${escapeHtml(p.name)}</div>
          <div class="product-barcode-text"><i class="bi bi-upc"></i> ${escapeHtml(p.barcode)}</div>
          <div class="d-flex justify-content-between align-items-center mt-2">
            <span class="product-price">${formatBaht(p.price)}</span>
          </div>
          <button class="btn btn-purple btn-sm w-100 mt-2" onclick="addToCartById('${p.id}')">
            <i class="bi bi-cart-plus"></i> เพิ่มลงตะกร้า
          </button>
        </div>
      </div>
    </div>
  `).join('');
}

function escapeHtml(str){
  const div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}

function addToCartById(productId){
  const product = products.find(p => p.id === productId);
  if(!product) return showToast('ไม่พบสินค้านี้ในระบบ', 'error');
  addToCart(product);
}

function addToCartByBarcode(barcode){
  const product = products.find(p => String(p.barcode).trim() === String(barcode).trim());
  if(!product){
    showToast(`ไม่พบสินค้ารหัสบาร์โค้ด "${barcode}"`, 'error');
    return;
  }
  addToCart(product);
}

function addToCart(product){
  const existing = cart.find(c => c.id === product.id);
  if(existing){
    existing.qty += 1;
  } else {
    cart.push({ id: product.id, name: product.name, price: product.price, cost: product.cost, qty: 1, barcode: product.barcode });
  }
  renderCart();
  showToast(`เพิ่ม "${product.name}" ลงตะกร้าแล้ว`, 'success');
}

function changeQty(productId, delta){
  const item = cart.find(c => c.id === productId);
  if(!item) return;
  item.qty += delta;
  if(item.qty <= 0){
    cart = cart.filter(c => c.id !== productId);
  }
  renderCart();
}

function removeFromCart(productId){
  cart = cart.filter(c => c.id !== productId);
  renderCart();
}

function getCartSubtotal(){
  return cart.reduce((sum, item) => sum + item.price * item.qty, 0);
}

function getCartDiscount(){
  if(!appliedCoupon) return 0;
  const subtotal = getCartSubtotal();
  return Math.min(appliedCoupon.amount, subtotal);
}

function getCartTotal(){
  return Math.max(0, getCartSubtotal() - getCartDiscount());
}

function renderCart(){
  const wrap = document.getElementById('cartItemsWrap');
  const countBadge = document.getElementById('cartCountBadge');
  const totalQty = cart.reduce((s,c)=>s+c.qty, 0);
  countBadge.textContent = totalQty;

  if(cart.length === 0){
    wrap.innerHTML = `<div class="text-center text-muted py-5">
        <i class="bi bi-cart-x fs-1"></i><div class="mt-2">ยังไม่มีสินค้าในตะกร้า</div>
      </div>`;
  } else {
    wrap.innerHTML = cart.map(item => `
      <div class="cart-item-row d-flex justify-content-between align-items-center">
        <div class="flex-grow-1 me-2">
          <div class="fw-500 small">${escapeHtml(item.name)}</div>
          <div class="text-muted" style="font-size:.75rem;">${formatBaht(item.price)} / ชิ้น</div>
        </div>
        <div class="d-flex align-items-center gap-2">
          <button class="qty-btn" onclick="changeQty('${item.id}', -1)">−</button>
          <span style="min-width:18px;text-align:center;">${item.qty}</span>
          <button class="qty-btn" onclick="changeQty('${item.id}', 1)">+</button>
        </div>
        <div class="ms-2 text-end" style="min-width:70px;">
          <div class="fw-600 small">${formatBaht(item.price*item.qty)}</div>
          <button class="btn btn-link btn-sm text-danger p-0" style="font-size:.75rem;" onclick="removeFromCart('${item.id}')">ลบ</button>
        </div>
      </div>
    `).join('');
  }

  document.getElementById('cartSubtotal').textContent = formatBaht(getCartSubtotal());
  document.getElementById('cartDiscount').textContent = '-' + formatBaht(getCartDiscount());
  document.getElementById('cartTotal').textContent = formatBaht(getCartTotal());

  const checkoutBtn = document.getElementById('checkoutBtn');
  checkoutBtn.disabled = cart.length === 0;
}

function applyCoupon(){
  const input = document.getElementById('couponInput');
  const code = input.value.trim().toUpperCase();
  const msgEl = document.getElementById('couponMsg');
  if(!code){ msgEl.innerHTML = ''; return; }

  const coupon = coupons.find(c => String(c.code).toUpperCase() === code);
  if(!coupon){
    appliedCoupon = null;
    msgEl.innerHTML = `<span class="text-danger"><i class="bi bi-x-circle"></i> ไม่พบโค้ดส่วนลดนี้</span>`;
    renderCart();
    return;
  }
  appliedCoupon = coupon;
  msgEl.innerHTML = `<span class="text-success"><i class="bi bi-check-circle"></i> ใช้โค้ด "${escapeHtml(coupon.code)}" ลด ${formatBaht(coupon.amount)}</span>`;
  renderCart();
  showToast('ใช้โค้ดส่วนลดสำเร็จ', 'success');
}

document.getElementById('barcodeInput').addEventListener('keydown', function(e){
  if(e.key === 'Enter'){
    e.preventDefault();
    const value = this.value.trim();
    if(value){
      addToCartByBarcode(value);
      this.value = '';
    }
  }
});

function openCameraScanner(target){
  cameraScanTarget = target; 
  const readerCustomer = document.getElementById('cameraReaderCustomer');
  const readerAdmin = document.getElementById('cameraReaderAdmin');
  const activeReaderId = target === 'admin' ? 'cameraReaderAdmin' : 'cameraReaderCustomer';

  readerCustomer.classList.toggle('d-none', target !== 'customer');
  readerAdmin.classList.toggle('d-none', target !== 'admin');

  const modalEl = document.getElementById('cameraModal');
  const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
  modal.show();

  modalEl.addEventListener('shown.bs.modal', function handler(){
    startCameraScanner(activeReaderId);
    modalEl.removeEventListener('shown.bs.modal', handler);
  });
}

function startCameraScanner(readerId){
  html5QrCode = new Html5Qrcode(readerId);
  const config = { fps: 10, qrbox: { width: 250, height: 150 } };

  html5QrCode.start(
    { facingMode: 'environment' },
    config,
    (decodedText) => {
      playBeep();
      if(cameraScanTarget === 'admin'){
        document.getElementById('pBarcode').value = decodedText;
        showToast('แสกนบาร์โค้ดสำเร็จ: ' + decodedText, 'success');
      } else {
        addToCartByBarcode(decodedText);
      }
      stopCameraScanner();
      bootstrap.Modal.getInstance(document.getElementById('cameraModal'))?.hide();
    },
    () => { }
  ).catch(() => {
    showToast('ไม่สามารถเปิดกล้องได้ กรุณาอนุญาตการเข้าถึงกล้อง', 'error');
  });
}

function stopCameraScanner(){
  if(html5QrCode){
    html5QrCode.stop().then(() => html5QrCode.clear()).catch(()=>{});
    html5QrCode = null;
  }
}

function playBeep(){
  const audio = document.getElementById('beepSound');
  audio.currentTime = 0;
  audio.play().catch(()=>{});
}

document.getElementById('paymentModal').addEventListener('show.bs.modal', function(){
  const total = getCartTotal();
  document.getElementById('cashTotalDisplay').textContent = formatBaht(total);
  document.getElementById('qrTotalDisplay').textContent = formatBaht(total);
  document.getElementById('cashReceivedInput').value = '';
  document.getElementById('changeDisplay').textContent = formatBaht(0);
  document.getElementById('confirmCashBtn').disabled = true;
  document.getElementById('cashWarning').classList.add('d-none');

  const qrWrap = document.getElementById('qrPayWrap');
  if(qrImageBase64){
    qrWrap.innerHTML = `<img src="${qrImageBase64}" alt="QR ชำระเงิน" style="width:220px;height:220px;object-fit:contain;border:1px solid var(--purple-100);border-radius:12px;">`;
  } else {
    qrWrap.innerHTML = `<div class="text-muted py-4"><i class="bi bi-qr-code fs-1"></i><div class="mt-2 small">ร้านค้ายังไม่ได้ตั้งค่า QR Code รับเงิน</div></div>`;
  }
});

document.getElementById('cashReceivedInput').addEventListener('input', function(){
  const total = getCartTotal();
  const received = parseFloat(this.value) || 0;
  const change = received - total;
  const confirmBtn = document.getElementById('confirmCashBtn');
  const warning = document.getElementById('cashWarning');
  const changeDisplay = document.getElementById('changeDisplay');

  if(received < total || received === 0){
    changeDisplay.textContent = formatBaht(Math.max(0,change));
    changeDisplay.classList.add('text-danger');
    warning.classList.remove('d-none');
    confirmBtn.disabled = true;
  } else {
    changeDisplay.textContent = formatBaht(change);
    changeDisplay.classList.remove('text-danger');
    warning.classList.add('d-none');
    confirmBtn.disabled = false;
  }
});

function confirmCashPayment(){
  const total = getCartTotal();
  const received = parseFloat(document.getElementById('cashReceivedInput').value) || 0;
  if(received < total){ return showToast('จำนวนเงินไม่เพียงพอ', 'error'); }
  const change = received - total;
  finalizeSale('เงินสด', received, change);
}

function confirmQRPayment(){
  finalizeSale('สแกนจ่าย (QR)', null, null);
}

// ยิงข้อมูลบันทึกบิลธุรกรรมการขายเข้า Google Sheets
async function finalizeSale(paymentMethod, received, change){
  const subtotal = getCartSubtotal();
  const discount = getCartDiscount();
  const total = getCartTotal();
  const totalCost = cart.reduce((sum, item) => sum + (item.cost * item.qty), 0);

  const transaction = {
    id: genBillNo(),
    datetime: new Date().toISOString(),
    paymentMethod,
    items: cart.map(c => ({ name: c.name, qty: c.qty, price: c.price })),
    subtotal, discount, total,
    received, change,
    cost: totalCost
  };

  // ส่งบันทึกลงชีต
  let res = await insertToSheet('transactions', transaction);
  if(res && res.status === 'success') {
    transactions.push(transaction); // sync state หน้าแอป
    bootstrap.Modal.getInstance(document.getElementById('paymentModal'))?.hide();
    renderReceipt(transaction);
    const receiptModal = bootstrap.Modal.getOrCreateInstance(document.getElementById('receiptModal'));
    receiptModal.show();
    showToast('ชำระเงินและบันทึกข้อมูลเรียบร้อย!', 'success');
  }
}

function renderReceipt(tx){
  const dt = new Date(tx.datetime);
  const dateStr = dt.toLocaleDateString('th-TH', { year:'numeric', month:'long', day:'numeric' });
  const timeStr = dt.toLocaleTimeString('th-TH', { hour:'2-digit', minute:'2-digit' });

  let itemsHtml = tx.items.map(it => `
    <div class="receipt-row">
      <span>${escapeHtml(it.name)} x${it.qty}</span>
      <span>${formatBaht(it.price * it.qty)}</span>
    </div>
  `).join('');

  let paymentDetailHtml = '';
  if(tx.paymentMethod === 'เงินสด'){
    paymentDetailHtml = `
      <div class="receipt-row"><span>รับเงินมา</span><span>${formatBaht(tx.received)}</span></div>
      <div class="receipt-row"><span>เงินทอน</span><span>${formatBaht(tx.change)}</span></div>
    `;
  }

  document.getElementById('receiptSlipContent').innerHTML = `
    <div class="text-center mb-2">
      <div class="r-title"><i class="bi bi-shop"></i> TleShope</div>
      <div class="text-muted small">ใบเสร็จรับเงิน / Receipt</div>
    </div>
    <hr>
    <div class="receipt-row"><span>เลขที่บิล</span><span>${tx.id}</span></div>
    <div class="receipt-row"><span>วันที่</span><span>${dateStr}</span></div>
    <div class="receipt-row"><span>เวลา</span><span>${timeStr} น.</span></div>
    <div class="receipt-row"><span>วิธีชำระเงิน</span><span>${tx.paymentMethod}</span></div>
    <hr>
    ${itemsHtml}
    <hr>
    <div class="receipt-row"><span>ยอดรวม</span><span>${formatBaht(tx.subtotal)}</span></div>
    <div class="receipt-row"><span>ส่วนลด</span><span>-${formatBaht(tx.discount)}</span></div>
    <div class="receipt-row fw-bold fs-6"><span>ยอดสุทธิ</span><span>${formatBaht(tx.total)}</span></div>
    ${paymentDetailHtml}
    <hr>
    <div class="text-center text-muted small mt-2">ขอบคุณที่ใช้บริการ TleShope 🙏</div>
  `;
}

function downloadReceiptPDF(){
  const element = document.getElementById('receiptSlipContent');
  const opt = {
    margin: 10,
    filename: `receipt_${Date.now()}.pdf`,
    image: { type: 'jpeg', quality: 0.98 },
    html2canvas: { scale: 2 },
    jsPDF: { unit: 'mm', format: [80, 150], orientation: 'portrait' }
  };
  html2pdf().set(opt).from(element).save();
  showToast('กำลังดาวน์โหลดใบเสร็จ...', 'info');
}

